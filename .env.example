# Preferred provider (no activation emails): Web3Forms
# 1) Create a free key at https://web3forms.com
# 2) Add the key below and restart dev server
VITE_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here

# Optional fallback provider (FormSubmit)
# If VITE_WEB3FORMS_ACCESS_KEY is missing, this endpoint will be used.
VITE_FORMSUBMIT_ENDPOINT=https://formsubmit.co/ajax/your-email@example.com
